{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "sortTailwindcss": {},
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "quoteProps": "as-needed",
  "jsxSingleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortPackageJson": true,
  "ignorePatterns": [
    ".next",
    "out",
    "dist/",
    "build/",
    "node_modules/",
    "*.generated.*",
    "payload-generated-schema.ts",
    "apps/docs/content/reference/api/**/*.md",
    "apps/docs/content/reference/api/**/*.mdx",
    "apps/docs/content/reference/api/**/_meta.js",
    "!apps/docs/content/reference/api/index.mdx",
    "*.log",
    ".env*",
    ".turbo/",
    ".cache/",
    "pnpm-lock.yaml",
    "package-lock.json",
    "yarn.lock",
    ".DS_Store",
    "Thumbs.db",
    "*.svg",
    "**/tests/fixtures/**",
    "**/fixtures/**",
    "packages/assets/logos/**/*.html",
    "coverage/",
    "test-results/",
    "playwright-report/",
    ".lint-results/",
    ".typecheck-results/",
    "payload-types.ts",
    "migrations/",
    "uploads/"
  ]
}

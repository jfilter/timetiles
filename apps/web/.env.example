# Environment configuration for TimeTiles
# Copy this to apps/web/.env and adjust values as needed
# Note: Next.js also supports .env.local for local overrides
#
# For structured settings (rate limits, quotas, batch sizes), see
# config/timetiles.example.yml — copy to config/timetiles.yml to customize.

# ─── Required ────────────────────────────────────────────────────────────────

# Database connection
# Use port 5432 for Docker (PG_MODE=docker) or 5433 for local Homebrew (PG_MODE=local)
# Test databases are derived automatically (e.g., timetiles_test_1, timetiles_test_2)
DATABASE_URL=postgresql://timetiles_user:timetiles_password@localhost:5432/timetiles

# Payload CMS secret (used for encryption — generate with: openssl rand -base64 32)
PAYLOAD_SECRET=your-secret-key-here

# Public URL of this instance (used for API URLs, emails, export links)
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3000

# ─── Optional ────────────────────────────────────────────────────────────────

# Public site URL (if different from NEXT_PUBLIC_PAYLOAD_URL, e.g. behind a CDN)
# Falls back to NEXT_PUBLIC_PAYLOAD_URL if not set
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Environment (development | production | test)
NODE_ENV=development

# Default locale when no user preference is set (en | de)
DEFAULT_LOCALE=en

# ─── File Paths ──────────────────────────────────────────────────────────────

# Base directory for all uploads (subfolders: /media, /import-files)
UPLOAD_DIR=uploads
UPLOAD_TEMP_DIR=./tmp

# Directory for data export files (CSV/JSON exports)
DATA_EXPORT_DIR=.exports

# ─── Logging ─────────────────────────────────────────────────────────────────

# Log level: trace, debug, info, warn, error, fatal, silent
# LOG_LEVEL=info

# Write logs to a file in addition to stdout (useful for Docker)
# LOG_FILE=/var/log/timetiles/app.log

# ─── Email ───────────────────────────────────────────────────────────────────

# Without SMTP settings, emails are logged to console (ethereal.email) in development
EMAIL_FROM_ADDRESS=noreply@timetiles.app
EMAIL_FROM_NAME=TimeTiles
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=your-smtp-user
# EMAIL_SMTP_PASS=your-smtp-password

# ─── Batch Processing ────────────────────────────────────────────────────────

# Override batch sizes from config/timetiles.yml (env vars take precedence)
# BATCH_SIZE_DUPLICATE_ANALYSIS=5000
# BATCH_SIZE_SCHEMA_DETECTION=10000
# BATCH_SIZE_EVENT_CREATION=1000
# BATCH_SIZE_DATABASE_CHUNK=1000

# ─── URL Fetch Cache ─────────────────────────────────────────────────────────

# Cache for scheduled import URL fetches (also configurable in timetiles.yml)
# URL_FETCH_CACHE_DIR=/tmp/url-fetch-cache
# URL_FETCH_CACHE_MAX_SIZE=104857600       # 100 MB
# URL_FETCH_CACHE_TTL=3600                 # 1 hour
# URL_FETCH_CACHE_MAX_TTL=2592000          # 30 days
# URL_FETCH_CACHE_RESPECT_CACHE_CONTROL=true

# ─── Security ────────────────────────────────────────────────────────────────

# Allow private/internal IPs in URL fetches (development only!)
# ALLOW_PRIVATE_URLS=true

# Enable DNS validation for SSRF protection
# SSRF_DNS_CHECK=true

# ─── Scraper Integration (optional) ─────────────────────────────────────────

# URL and API key for the TimeScrape runner service
# SCRAPER_RUNNER_URL=http://localhost:4000
# SCRAPER_API_KEY=your-scraper-api-key-min-16-chars

{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "description": "The web application for TimeTiles, providing the main user interface and data exploration features.",
  "type": "module",
  "scripts": {
    "dev": "./scripts/job-runner.sh & next dev --turbopack",
    "dev:debug": "LOG_LEVEL=debug next dev --turbopack",
    "build": "payload generate:types --silent && next build",
    "build:compile": "payload generate:types --silent && payload generate:importmap --silent && next build --experimental-build-mode compile",
    "start": "next start",
    "lint": "oxlint --config ../../.oxlintrc.json . && eslint app lib components tests scripts --ext .ts,.tsx,.js,.jsx --cache",
    "format": "eslint app lib components tests scripts --ext .ts,.tsx,.js,.jsx --cache --fix --quiet && oxfmt --write .",
    "typecheck": "tsx ../../scripts/typecheck-with-json.ts",
    "typecheck:fast": "tsgo --noEmit",
    "check:ai": "tsx scripts/check-summary.ts",
    "payload": "payload",
    "payload:generate": "tsx scripts/generate-payload.ts",
    "payload:migrate": "payload migrate",
    "payload:migrate:create": "payload migrate:create",
    "payload:validate": "tsx scripts/validate-types.ts",
    "seed": "dotenv -e ../../.env -e .env.local -- tsx scripts/seed.ts",
    "test": "vitest run",
    "test:ai": "tsx scripts/test-ai.ts",
    "test:silent": "vitest run --reporter=basic --silent",
    "test:debug": "LOG_LEVEL=debug vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage --coverage.reportOnFailure=true",
    "test:coverage:summary": "tsx scripts/coverage-summary.ts",
    "test:coverage:check": "tsx scripts/coverage-summary.ts --threshold 80",
    "setup:e2e-db": "dotenv -e .env.local -- tsx scripts/e2e-setup-database.ts",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug --headed",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "demo-data": "dotenv -e ../../.env -e .env.local -- tsx scripts/load-demo-data.ts",
    "packages": "dotenv -e ../../.env -e .env.local -- tsx scripts/manage-packages.ts",
    "heal": "dotenv -e ../../.env -e .env.local -- tsx scripts/heal.ts",
    "setup-site": "dotenv -e ../../.env -e .env.local -- tsx scripts/setup-site.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@cfworker/json-schema": "^4.1.1",
    "@payloadcms/db-postgres": "3.80.0",
    "@payloadcms/email-nodemailer": "3.80.0",
    "@payloadcms/next": "3.80.0",
    "@payloadcms/richtext-lexical": "3.80.0",
    "@payloadcms/translations": "3.80.0",
    "@payloadcms/ui": "3.80.0",
    "@tanstack/react-query": "^5.94.5",
    "@tanstack/react-query-devtools": "^5.94.5",
    "@timetiles/assets": "workspace:*",
    "@timetiles/ui": "workspace:*",
    "@types/archiver": "^7.0.0",
    "@types/node-geocoder": "^4.2.6",
    "@types/papaparse": "^5.5.2",
    "@xyflow/react": "^12.10.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "expr-eval": "^2.0.2",
    "franc": "catalog:",
    "graphql": "^16.13.1",
    "lru-cache": "^11.2.7",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.21.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "next-themes": "catalog:",
    "node-geocoder": "^4.4.1",
    "nodemailer": "^7.0.13",
    "nuqs": "^2.8.9",
    "papaparse": "^5.5.3",
    "payload": "3.80.0",
    "pg": "^8.20.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.3",
    "quicktype-core": "^23.2.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-map-gl": "^8.1.0",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.5",
    "tsx": "catalog:",
    "uuid": "^13.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "yaml": "^2.8.3",
    "zod": "catalog:",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@svgr/webpack": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@timetiles/eslint-config": "workspace:*",
    "@timetiles/typescript-config": "workspace:*",
    "@types/geojson": "^7946.0.16",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/spy": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "echarts": "catalog:",
    "echarts-for-react": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-i18next": "^6.1.3",
    "happy-dom": "^20.8.4",
    "jsdom": "^28.1.0",
    "msw": "^2.12.14",
    "playwright": "^1.58.2",
    "typescript": "catalog:",
    "vitest": "^4.1.1"
  }
}

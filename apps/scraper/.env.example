# TimeScrape Runner Configuration
# Copy this to apps/scraper/.env and adjust values

# API key shared between TimeTiles web app and runner (REQUIRED)
# Must be at least 16 characters
SCRAPER_API_KEY=change-me-to-a-secure-random-string

# Server port (default: 4000)
SCRAPER_PORT=4000

# Maximum concurrent scraper runs (default: 3)
SCRAPER_MAX_CONCURRENT=3

# Default timeout for scraper execution in seconds (default: 300)
SCRAPER_DEFAULT_TIMEOUT=300

# Default memory limit for scraper containers in MB (default: 512)
SCRAPER_DEFAULT_MEMORY=512

# Maximum git repository size in MB (default: 50)
SCRAPER_MAX_REPO_SIZE_MB=50

# Maximum output CSV size in MB (default: 100)
SCRAPER_MAX_OUTPUT_SIZE_MB=100

# Temporary directory for scraper workspaces (default: /tmp/timescrape)
SCRAPER_DATA_DIR=/tmp/timescrape

# Log level (default: info)
LOG_LEVEL=info

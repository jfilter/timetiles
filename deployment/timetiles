#!/bin/bash

# TimeTiles CLI - Production Management
# Usage: timetiles [command]
# Runs as 'timetiles' user (root auto-switches). Install via:
#   sudo ln -sf /opt/timetiles/timetiles /usr/local/bin/timetiles

set -eo pipefail

DEPLOY_USER="${DEPLOY_USER:-timetiles}"

# If running as root, re-exec as the deploy user with docker group
if [ "$(id -u)" = "0" ]; then
    # Check if deploy user exists
    if id "$DEPLOY_USER" &>/dev/null; then
        # Shell-escape each argument to prevent injection via sg -c
        ESCAPED_ARGS=$(printf '%q ' "$@")
        exec sg docker -c "sudo -u $DEPLOY_USER $0 $ESCAPED_ARGS"
    else
        echo "Warning: User '$DEPLOY_USER' not found, running as root"
    fi
fi

if ! docker info &>/dev/null 2>&1; then
    echo "Warning: Cannot connect to Docker. You may need to:"
    echo "  1. Start Docker daemon"
    echo "  2. Add user to docker group: sudo usermod -aG docker $USER"
    echo "  3. Re-login or run: sg docker -c './timetiles <command>'"
fi

SCRIPT_DIR="$( cd "$( dirname "$(readlink -f "${BASH_SOURCE[0]}")" )" && pwd )"
ENV_FILE="$SCRIPT_DIR/.env.production"
COMPOSE_FILE="$SCRIPT_DIR/docker-compose.prod.yml"
TEST_OVERRIDE="$SCRIPT_DIR/docker-compose.test.yml"
SSL_OVERRIDE="$SCRIPT_DIR/docker-compose.ssl-override.yml"

# Build compose command, layering optional overrides
DC_CMD="docker compose -f $COMPOSE_FILE"
BUILD_OVERRIDE="$SCRIPT_DIR/docker-compose.override.yml"
[ -f "$BUILD_OVERRIDE" ] && DC_CMD="$DC_CMD -f $BUILD_OVERRIDE"
[ -f "$SSL_OVERRIDE" ]   && DC_CMD="$DC_CMD -f $SSL_OVERRIDE"
[ -f "$TEST_OVERRIDE" ]  && DC_CMD="$DC_CMD -f $TEST_OVERRIDE"
DC_CMD="$DC_CMD --env-file $ENV_FILE"

cd "$SCRIPT_DIR/.."

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ALERT_SCRIPT="/opt/timetiles/scripts/alert.sh"

send_alert() {
    local subject="$1"
    local message="$2"
    if [ -x "$ALERT_SCRIPT" ]; then
        "$ALERT_SCRIPT" "$subject" "$message" 2>/dev/null || true
    fi
}

# Restic configuration
load_restic_config() {
    # Extract only backup-related variables (not full env source to avoid leaking secrets)
    # Uses cut instead of IFS='=' to preserve values containing '=' (e.g., base64 passwords)
    while IFS= read -r line; do
        local key="${line%%=*}"
        local value="${line#*=}"
        case "$key" in
            RESTIC_PASSWORD|RESTIC_REPOSITORY|RESTIC_OFFSITE_REPOSITORY|\
            AWS_ACCESS_KEY_ID|AWS_SECRET_ACCESS_KEY|AWS_ENDPOINT_URL|\
            BACKUP_KEEP_DAILY|BACKUP_KEEP_WEEKLY|BACKUP_KEEP_MONTHLY|\
            UPLOAD_HOST_DIR)
                # Remove surrounding quotes if present
                value="${value%\"}"
                value="${value#\"}"
                export "$key=$value"
                ;;
        esac
    done < <(grep -E '^(RESTIC_|AWS_|BACKUP_KEEP_|UPLOAD_HOST_DIR)' "$ENV_FILE" 2>/dev/null || true)

    RESTIC_PASSWORD="${RESTIC_PASSWORD:-}"
    RESTIC_REPOSITORY="${RESTIC_REPOSITORY:-$SCRIPT_DIR/backups/restic-repo}"
    RESTIC_OFFSITE_REPOSITORY="${RESTIC_OFFSITE_REPOSITORY:-}"
    AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID:-}"
    AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY:-}"
    AWS_ENDPOINT_URL="${AWS_ENDPOINT_URL:-}"
    BACKUP_KEEP_DAILY="${BACKUP_KEEP_DAILY:-7}"
    BACKUP_KEEP_WEEKLY="${BACKUP_KEEP_WEEKLY:-4}"
    BACKUP_KEEP_MONTHLY="${BACKUP_KEEP_MONTHLY:-12}"

    if [[ -z "$RESTIC_PASSWORD" ]]; then
        echo -e "${RED}Error: RESTIC_PASSWORD not set in .env.production${NC}"
        echo "Run bootstrap or manually set RESTIC_PASSWORD"
        exit 1
    fi

    # Resolve relative UPLOAD_HOST_DIR against deployment dir (not cwd,
    # which is $SCRIPT_DIR/.. due to line 62 cd for build context)
    if [[ -n "${UPLOAD_HOST_DIR:-}" && "${UPLOAD_HOST_DIR:0:1}" != "/" ]]; then
        UPLOAD_HOST_DIR="$SCRIPT_DIR/$UPLOAD_HOST_DIR"
    fi

    export RESTIC_PASSWORD
    export AWS_ACCESS_KEY_ID
    export AWS_SECRET_ACCESS_KEY
}

# Initialize restic repo if needed
init_restic_repo() {
    local repo="$1"
    local name="$2"

    if [[ "$repo" == s3:* ]]; then
        export AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY
        [[ -n "$AWS_ENDPOINT_URL" ]] && export AWS_ENDPOINT_URL
    fi

    # Check if repo exists
    if ! restic -r "$repo" snapshots &>/dev/null; then
        echo -e "${YELLOW}Initializing $name restic repository...${NC}"
        if ! restic -r "$repo" init 2>&1; then
            # Might already be initialized (race condition or permissions)
            if ! restic -r "$repo" snapshots &>/dev/null; then
                echo -e "${RED}Failed to initialize $name repository${NC}"
                return 1
            fi
        fi
    fi
    return 0
}

# Run restic with proper environment
run_restic() {
    local repo="$1"
    shift

    if [[ "$repo" == s3:* ]]; then
        export AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY
        [[ -n "$AWS_ENDPOINT_URL" ]] && export AWS_ENDPOINT_URL
    fi

    restic -r "$repo" "$@"
}

# Functions
print_usage() {
    echo "Usage: $0 [command]"
    echo ""
    echo "Commands:"
    echo "  setup     - Initial setup (copy env file, generate secrets)"
    echo "  build     - Build Docker images (or pull from registry)"
    echo "  pull      - Pull images from registry"
    echo "  up        - Start all services"
    echo "  down      - Stop all services"
    echo "  restart   - Restart all services"
    echo "  logs            - View all logs (web + scraper merged)"
    echo "  logs --web      - View web app logs only"
    echo "  logs --scraper  - View scraper logs only"
    echo "  logs --files    - Tail persistent log files (/var/log/timetiles/)"
    echo "  backup       - Backup management (full|db|uploads|auto|list|prune|verify|clean)"
    echo "  restore   - Restore from backup"
    echo "  status    - Check service status"
    echo "  ssl       - Initialize Let's Encrypt SSL certificate"
    echo "  update    - Pull latest code and redeploy"
    echo "  check     - Verify all deployment aspects are properly configured"
    echo "  version   - Show version information"
    echo ""
    echo "Note: Database migrations run automatically on container startup."
    echo ""
}

check_env() {
    if [ ! -f "$ENV_FILE" ]; then
        echo -e "${RED}Error: $ENV_FILE not found!${NC}"
        echo "Run: $0 setup"
        exit 1
    fi
}

# Load specific variables from env file without exposing secrets
# Usage: load_env_vars VAR1 VAR2 ...
load_env_vars() {
    local wanted="$*"
    while IFS= read -r line; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        local key="${line%%=*}"
        local value="${line#*=}"
        for var in $wanted; do
            if [[ "$key" == "$var" ]]; then
                value="${value%\"}"
                value="${value#\"}"
                export "$key=$value"
                break
            fi
        done
    done < "$ENV_FILE"
}

init_ssl() {
    echo -e "${YELLOW}Initializing SSL certificate with Let's Encrypt...${NC}"

    # Load only domain/email from env file
    load_env_vars DOMAIN_NAME LETSENCRYPT_EMAIL
    
    if [ -z "$DOMAIN_NAME" ]; then
        echo -e "${RED}Error: DOMAIN_NAME not set in $ENV_FILE${NC}"
        exit 1
    fi
    
    if [ -z "$LETSENCRYPT_EMAIL" ]; then
        echo -e "${RED}Error: LETSENCRYPT_EMAIL not set in $ENV_FILE${NC}"
        exit 1
    fi
    
    echo -e "${YELLOW}Requesting certificate for $DOMAIN_NAME...${NC}"
    
    # Check if www DNS exists before requesting both domains
    SSL_DOMAINS="-d $DOMAIN_NAME"
    if host "www.$DOMAIN_NAME" >/dev/null 2>&1; then
        SSL_DOMAINS="$SSL_DOMAINS -d www.$DOMAIN_NAME"
    else
        echo -e "${YELLOW}No DNS record for www.$DOMAIN_NAME, requesting cert for $DOMAIN_NAME only${NC}"
    fi

    # Request certificate — use base compose only (no SSL override) so certbot
    # writes to the Docker letsencrypt volume, not the self-signed host mount
    CERTBOT_DC="docker compose -f $COMPOSE_FILE"
    [ -f "$BUILD_OVERRIDE" ] && CERTBOT_DC="$CERTBOT_DC -f $BUILD_OVERRIDE"
    [ -f "$TEST_OVERRIDE" ]  && CERTBOT_DC="$CERTBOT_DC -f $TEST_OVERRIDE"
    CERTBOT_DC="$CERTBOT_DC --env-file $ENV_FILE"

    if $CERTBOT_DC run --rm certbot certonly --webroot \
        --webroot-path=/var/www/certbot \
        --email "$LETSENCRYPT_EMAIL" \
        --agree-tos \
        --no-eff-email \
        $SSL_DOMAINS; then
        echo -e "${GREEN}SSL certificate obtained successfully!${NC}"

        # Remove self-signed SSL override if present (so nginx uses the letsencrypt volume)
        if [[ -f "$SSL_OVERRIDE" ]]; then
            echo -e "${YELLOW}Removing self-signed SSL override...${NC}"
            rm -f "$SSL_OVERRIDE"
            # Rebuild compose command without the override
            DC_CMD="docker compose -f $COMPOSE_FILE"
            [ -f "$BUILD_OVERRIDE" ] && DC_CMD="$DC_CMD -f $BUILD_OVERRIDE"
            [ -f "$TEST_OVERRIDE" ]  && DC_CMD="$DC_CMD -f $TEST_OVERRIDE"
            DC_CMD="$DC_CMD --env-file $ENV_FILE"
            # Recreate nginx to pick up new volume config
            $DC_CMD up -d --no-deps --force-recreate nginx
        else
            # Reload nginx to use new certificate
            $DC_CMD exec nginx nginx -s reload
        fi
    else
        echo -e "${RED}Failed to obtain SSL certificate${NC}"
        exit 1
    fi
}

case "$1" in
    setup)
        echo -e "${YELLOW}Setting up production environment...${NC}"
        
        # Copy env file if it doesn't exist
        if [ ! -f "$ENV_FILE" ]; then
            cp "$SCRIPT_DIR/.env.production.example" "$ENV_FILE"
            echo -e "${GREEN}Created $ENV_FILE from template${NC}"
            
            # Generate random secret for Payload
            PAYLOAD_SECRET=$(openssl rand -base64 32 | tr -d '/+=')
            # Use a delimiter that won't appear in base64 strings
            sed -i.bak "s|PAYLOAD_SECRET=.*|PAYLOAD_SECRET=$PAYLOAD_SECRET|" "$ENV_FILE"
            echo -e "${GREEN}Generated PAYLOAD_SECRET${NC}"
            
            echo -e "${YELLOW}Please edit $ENV_FILE and set:${NC}"
            echo "  - DB_PASSWORD"
            echo "  - DOMAIN_NAME (your domain)"
            echo "  - LETSENCRYPT_EMAIL"
        else
            echo -e "${YELLOW}$ENV_FILE already exists${NC}"
        fi
        ;;
        
    build)
        check_env
        if [ -f "$BUILD_OVERRIDE" ]; then
            echo -e "${YELLOW}Building Docker images locally (override detected)...${NC}"
            if ! $DC_CMD build; then
                echo -e "${RED}Local build failed!${NC}"
                exit 1
            fi
            echo -e "${GREEN}Build complete!${NC}"
        else
            echo -e "${YELLOW}Pulling Docker images from registry...${NC}"
            $DC_CMD pull
            echo -e "${GREEN}Pull complete!${NC}"
        fi
        ;;

    pull)
        check_env
        echo -e "${YELLOW}Pulling Docker images from registry...${NC}"
        $DC_CMD pull
        echo -e "${GREEN}Pull complete!${NC}"
        ;;

    up)
        check_env
        load_env_vars UPLOAD_HOST_DIR DB_USER
        # Resolve relative path against deployment dir (cwd is $SCRIPT_DIR/..)
        if [[ -n "${UPLOAD_HOST_DIR:-}" && "${UPLOAD_HOST_DIR:0:1}" != "/" ]]; then
            UPLOAD_HOST_DIR="$SCRIPT_DIR/$UPLOAD_HOST_DIR"
        fi
        # Ensure uploads directory exists with correct ownership for the
        # container's nextjs user (uid 1001). Without this, Docker creates
        # the bind mount as root and the app can't write uploads.
        UPLOAD_HOST_DIR="${UPLOAD_HOST_DIR:-$SCRIPT_DIR/uploads}"
        mkdir -p "$UPLOAD_HOST_DIR"
        if [[ "$(stat -c %u "$UPLOAD_HOST_DIR" 2>/dev/null || stat -f %u "$UPLOAD_HOST_DIR")" != "1001" ]]; then
            if ! sudo chown 1001:1001 "$UPLOAD_HOST_DIR" 2>/dev/null; then
                echo -e "${YELLOW}Warning: Cannot set ownership on $UPLOAD_HOST_DIR to uid 1001${NC}"
                echo "On Linux servers, run: sudo chown 1001:1001 $UPLOAD_HOST_DIR"
                echo "On Docker Desktop (macOS/Windows) this is usually fine — uid mapping is handled automatically."
            fi
        fi
        echo -e "${YELLOW}Starting services...${NC}"

        # Start postgres first and wait for it to be ready before other services.
        # kartoza/postgis restarts during first-run init (extensions, users, etc.)
        # which causes Docker Compose depends_on health gates to fail immediately.
        # We wait for pg_isready to succeed AND stay stable for 3 consecutive checks
        # to ensure the kartoza restart cycle has completed.
        $DC_CMD up -d --no-deps postgres
        echo "Waiting for PostgreSQL to be ready..."
        pg_attempts=0
        pg_max=90
        pg_consecutive=0
        pg_required=3
        while [[ $pg_attempts -lt $pg_max ]]; do
            if $DC_CMD exec -T postgres pg_isready -h localhost -U "${DB_USER:-timetiles_user}" &>/dev/null; then
                ((++pg_consecutive))
                if [[ $pg_consecutive -ge $pg_required ]]; then
                    echo -e "${GREEN}PostgreSQL is ready (stable)${NC}"
                    break
                fi
            else
                pg_consecutive=0
            fi
            echo -n "."
            sleep 2
            ((++pg_attempts))
        done
        if [[ $pg_attempts -ge $pg_max ]]; then
            echo ""
            echo -e "${RED}PostgreSQL failed to become ready${NC}"
            exit 1
        fi

        # Now start remaining services (postgres is already healthy)
        $DC_CMD up -d
        echo -e "${GREEN}Services started!${NC}"
        echo "Waiting for application to be ready..."
        sleep 5
        "$SCRIPT_DIR/timetiles" status
        ;;
        
    down)
        check_env
        echo -e "${YELLOW}Stopping services...${NC}"
        $DC_CMD down --remove-orphans
        echo -e "${GREEN}Services stopped!${NC}"
        ;;
        
    restart)
        check_env
        echo -e "${YELLOW}Restarting services...${NC}"
        $DC_CMD restart
        echo -e "${GREEN}Services restarted!${NC}"
        ;;
        
    logs)
        check_env
        case "${2:-}" in
            --web)
                $DC_CMD logs -f --tail=100
                ;;
            --scraper)
                journalctl -u timescrape-runner -f --no-pager -n 100
                ;;
            --files)
                tail -f /var/log/timetiles/*.log 2>/dev/null || echo "No log files found in /var/log/timetiles/"
                ;;
            *)
                # Show both Docker and scraper logs merged
                $DC_CMD logs -f --tail=100 2>&1 | sed 's/^/[web] /' &
                WEB_PID=$!
                if systemctl is-active --quiet timescrape-runner 2>/dev/null; then
                    journalctl -u timescrape-runner -f --no-pager -n 100 2>&1 | sed 's/^/[scraper] /' &
                    SCRAPER_PID=$!
                fi
                trap 'kill $WEB_PID ${SCRAPER_PID:-} 2>/dev/null; exit' INT TERM
                wait
                ;;
        esac
        ;;
        
    backup)
        check_env
        load_restic_config

        OFFSITE=false
        WHAT="full"

        # Parse arguments
        while [[ $# -gt 1 ]]; do
            case "$2" in
                --offsite) OFFSITE=true; shift ;;
                db|database) WHAT="db"; shift ;;
                uploads) WHAT="uploads"; shift ;;
                list|prune|verify|auto) WHAT="$2"; shift; break ;;
                *) shift ;;
            esac
        done

        case "$WHAT" in
            db|database)
                # Initialize local repo
                if ! init_restic_repo "$RESTIC_REPOSITORY" "local"; then
                    exit 1
                fi

                echo -e "${YELLOW}Backing up database...${NC}"

                # Create temp SQL dump
                TEMP_DUMP=$(mktemp)
                trap "rm -f $TEMP_DUMP" EXIT INT TERM

                if ! $DC_CMD exec -T postgres bash -c 'PGPASSWORD=$POSTGRES_PASS pg_dump -h localhost -U $POSTGRES_USER --clean --if-exists $POSTGRES_DBNAME' > "$TEMP_DUMP"; then
                    echo -e "${RED}Database dump failed${NC}"
                    send_alert "Backup Failed" "Database dump failed at $(date)"
                    exit 1
                fi

                # Backup to local restic repo
                if ! run_restic "$RESTIC_REPOSITORY" backup --tag db --stdin --stdin-filename "database.sql" < "$TEMP_DUMP"; then
                    echo -e "${RED}Restic backup failed${NC}"
                    send_alert "Backup Failed" "Restic backup failed at $(date)"
                    exit 1
                fi

                echo -e "${GREEN}Database backup complete${NC}"

                # Offsite sync
                if $OFFSITE && [[ -n "$RESTIC_OFFSITE_REPOSITORY" ]]; then
                    echo -e "${YELLOW}Syncing to offsite...${NC}"
                    if init_restic_repo "$RESTIC_OFFSITE_REPOSITORY" "offsite" 2>/dev/null; then
                        if run_restic "$RESTIC_OFFSITE_REPOSITORY" backup --tag db --stdin --stdin-filename "database.sql" < "$TEMP_DUMP" 2>/dev/null; then
                            echo -e "${GREEN}Offsite sync complete${NC}"
                        else
                            echo -e "${YELLOW}Offsite sync failed (continuing - local backup succeeded)${NC}"
                        fi
                    else
                        echo -e "${YELLOW}Offsite init failed (write-only credentials?) - skipping${NC}"
                    fi
                fi
                ;;

            uploads)
                if ! init_restic_repo "$RESTIC_REPOSITORY" "local"; then
                    exit 1
                fi

                echo -e "${YELLOW}Backing up uploads...${NC}"

                UPLOAD_HOST_DIR="${UPLOAD_HOST_DIR:-$SCRIPT_DIR/uploads}"
                if [[ ! -d "$UPLOAD_HOST_DIR" ]]; then
                    echo -e "${RED}Upload directory not found: $UPLOAD_HOST_DIR${NC}"
                    exit 1
                fi

                if ! run_restic "$RESTIC_REPOSITORY" backup --tag uploads "$UPLOAD_HOST_DIR"; then
                    echo -e "${RED}Uploads backup failed${NC}"
                    send_alert "Backup Failed" "Uploads backup failed at $(date)"
                    exit 1
                fi

                echo -e "${GREEN}Uploads backup complete${NC}"

                # Offsite sync for uploads
                if $OFFSITE && [[ -n "$RESTIC_OFFSITE_REPOSITORY" ]]; then
                    echo -e "${YELLOW}Syncing uploads to offsite...${NC}"
                    if run_restic "$RESTIC_OFFSITE_REPOSITORY" backup --tag uploads "$UPLOAD_HOST_DIR" 2>/dev/null; then
                        echo -e "${GREEN}Offsite uploads sync complete${NC}"
                    else
                        echo -e "${YELLOW}Offsite uploads sync failed (continuing)${NC}"
                    fi
                fi
                ;;

            full)
                echo -e "${YELLOW}Creating full backup (database + uploads)...${NC}"

                # Run both backups
                BACKUP_ARGS=""
                $OFFSITE && BACKUP_ARGS="--offsite"

                "$SCRIPT_DIR/timetiles" backup db $BACKUP_ARGS || exit 1
                "$SCRIPT_DIR/timetiles" backup uploads $BACKUP_ARGS || exit 1

                echo -e "${GREEN}Full backup complete${NC}"
                ;;

            list)
                REPO="$RESTIC_REPOSITORY"
                if [[ "$2" == "--offsite" ]]; then
                    if [[ -z "$RESTIC_OFFSITE_REPOSITORY" ]]; then
                        echo -e "${RED}No offsite repository configured${NC}"
                        exit 1
                    fi
                    REPO="$RESTIC_OFFSITE_REPOSITORY"
                    echo -e "${YELLOW}Listing offsite snapshots...${NC}"
                    echo -e "${YELLOW}(Requires read permissions - may fail with write-only credentials)${NC}"
                fi

                if ! run_restic "$REPO" snapshots 2>/dev/null; then
                    if [[ "$REPO" == "$RESTIC_OFFSITE_REPOSITORY" ]]; then
                        echo -e "${YELLOW}Cannot list offsite snapshots (read permissions required)${NC}"
                        echo "Use AWS console or a machine with read access to view offsite backups"
                    else
                        echo -e "${RED}Failed to list snapshots${NC}"
                        exit 1
                    fi
                fi
                ;;

            prune)
                echo -e "${YELLOW}Applying retention policy...${NC}"
                echo "Keeping: $BACKUP_KEEP_DAILY daily, $BACKUP_KEEP_WEEKLY weekly, $BACKUP_KEEP_MONTHLY monthly"

                # Prune local
                if run_restic "$RESTIC_REPOSITORY" forget \
                    --keep-daily "$BACKUP_KEEP_DAILY" \
                    --keep-weekly "$BACKUP_KEEP_WEEKLY" \
                    --keep-monthly "$BACKUP_KEEP_MONTHLY" \
                    --prune; then
                    echo -e "${GREEN}Local repository pruned${NC}"
                else
                    echo -e "${RED}Local prune failed${NC}"
                    exit 1
                fi

                # Prune offsite (may fail with write-only)
                if [[ -n "$RESTIC_OFFSITE_REPOSITORY" ]]; then
                    echo -e "${YELLOW}Pruning offsite repository...${NC}"
                    if run_restic "$RESTIC_OFFSITE_REPOSITORY" forget \
                        --keep-daily "$BACKUP_KEEP_DAILY" \
                        --keep-weekly "$BACKUP_KEEP_WEEKLY" \
                        --keep-monthly "$BACKUP_KEEP_MONTHLY" \
                        --prune 2>/dev/null; then
                        echo -e "${GREEN}Offsite repository pruned${NC}"
                    else
                        echo -e "${YELLOW}Offsite prune skipped (delete permissions required)${NC}"
                        echo "Use S3 lifecycle rules to expire old offsite backups"
                    fi
                fi
                ;;

            verify)
                echo -e "${YELLOW}Verifying backup repository...${NC}"

                if run_restic "$RESTIC_REPOSITORY" check; then
                    echo -e "${GREEN}Local repository verified${NC}"
                else
                    echo -e "${RED}Local repository has errors${NC}"
                    send_alert "Backup Verify Failed" "Local backup repository verification failed"
                    exit 1
                fi

                # Show recent snapshots
                echo ""
                echo "Recent snapshots:"
                run_restic "$RESTIC_REPOSITORY" snapshots --last 5
                ;;

            auto)
                CRON_OFFSITE=""
                DISABLE=false

                for arg in "${@:2}"; do
                    case "$arg" in
                        --offsite) CRON_OFFSITE="--offsite" ;;
                        --disable) DISABLE=true ;;
                    esac
                done

                CRON_SCRIPT="$SCRIPT_DIR/backups/auto-backup.sh"
                mkdir -p "$SCRIPT_DIR/backups"

                if $DISABLE; then
                    echo -e "${YELLOW}Disabling automatic backups...${NC}"
                    crontab -l 2>/dev/null | grep -v "$CRON_SCRIPT" | crontab -
                    rm -f "$CRON_SCRIPT"
                    echo -e "${GREEN}Automatic backups disabled${NC}"
                else
                    echo -e "${YELLOW}Setting up automatic daily backups...${NC}"

                    cat > "$CRON_SCRIPT" << EOF
#!/bin/bash
exec 200>/var/lock/timetiles-backup.lock
flock -n 200 || { echo "Backup already running, skipping"; exit 0; }
cd "$SCRIPT_DIR"
./timetiles backup $CRON_OFFSITE
./timetiles backup prune
EOF
                    chmod +x "$CRON_SCRIPT"

                    # Add to crontab (daily at 2 AM)
                    CRON_CMD="0 2 * * * $CRON_SCRIPT >> /var/log/timetiles/backup.log 2>&1"
                    (crontab -l 2>/dev/null | grep -v "$CRON_SCRIPT"; echo "$CRON_CMD") | crontab -

                    echo -e "${GREEN}Automatic backups configured (daily at 2 AM)${NC}"
                    [[ -n "$CRON_OFFSITE" ]] && echo "Offsite sync enabled"
                    echo "Logs: /var/log/timetiles/backup.log"
                    echo "To disable: timetiles backup auto --disable"
                fi
                ;;

            *)
                echo "Usage: $0 backup [--offsite] [db|uploads|full]"
                echo "       $0 backup list [--offsite]"
                echo "       $0 backup prune"
                echo "       $0 backup verify"
                echo "       $0 backup auto [--offsite] [--disable]"
                echo ""
                echo "Commands:"
                echo "  full      - Backup database and uploads (default)"
                echo "  db        - Backup database only"
                echo "  uploads   - Backup uploads only"
                echo "  list      - List snapshots"
                echo "  prune     - Apply retention policy"
                echo "  verify    - Check repository integrity"
                echo "  auto      - Setup automatic daily backups"
                echo ""
                echo "Options:"
                echo "  --offsite - Also sync to S3 (for backup/auto)"
                echo "            - List from S3 (for list)"
                exit 1
                ;;
        esac
        ;;
        
    restore)
        check_env
        load_restic_config

        SNAPSHOT="${2:-}"
        OFFSITE=false

        # Check for --offsite flag
        for arg in "$@"; do
            [[ "$arg" == "--offsite" ]] && OFFSITE=true
        done

        REPO="$RESTIC_REPOSITORY"
        if $OFFSITE; then
            if [[ -z "$RESTIC_OFFSITE_REPOSITORY" ]]; then
                echo -e "${RED}No offsite repository configured${NC}"
                exit 1
            fi
            REPO="$RESTIC_OFFSITE_REPOSITORY"
            echo -e "${YELLOW}Restoring from offsite repository...${NC}"
            echo -e "${YELLOW}(Requires read permissions)${NC}"
        fi

        # If no snapshot specified, list and prompt
        if [[ -z "$SNAPSHOT" ]] || [[ "$SNAPSHOT" == "--offsite" ]]; then
            echo -e "${YELLOW}Available snapshots:${NC}"
            if ! run_restic "$REPO" snapshots 2>/dev/null; then
                if $OFFSITE; then
                    echo -e "${RED}Cannot list offsite snapshots (read permissions required)${NC}"
                    echo "Use AWS console to find snapshot ID, then run:"
                    echo "  timetiles restore <snapshot-id> --offsite"
                fi
                exit 1
            fi
            echo ""
            echo "Usage: timetiles restore <snapshot-id> [--offsite] [--force]"
            echo "       timetiles restore latest [--offsite] [--force]"
            exit 0
        fi

        # Handle 'latest' keyword
        if [[ "$SNAPSHOT" == "latest" ]]; then
            SNAPSHOT=$(run_restic "$REPO" snapshots --json 2>/dev/null | jq -r 'sort_by(.time) | last | .short_id // empty')
            if [[ -z "$SNAPSHOT" ]]; then
                echo -e "${RED}No snapshots found${NC}"
                exit 1
            fi
            echo "Latest snapshot: $SNAPSHOT"
        fi

        # Get snapshot info
        SNAPSHOT_INFO=$(run_restic "$REPO" snapshots --json "$SNAPSHOT" 2>/dev/null)
        if [[ -z "$SNAPSHOT_INFO" ]] || [[ "$SNAPSHOT_INFO" == "[]" ]]; then
            echo -e "${RED}Snapshot not found: $SNAPSHOT${NC}"
            exit 1
        fi

        TAGS=$(echo "$SNAPSHOT_INFO" | jq -r '.[0].tags // [] | join(",")')
        echo "Snapshot $SNAPSHOT tags: $TAGS"

        # Skip confirmation with --force flag
        FORCE=false
        for arg in "$@"; do
            [[ "$arg" == "--force" ]] && FORCE=true
        done

        # Confirm restore
        if [[ "$FORCE" != "true" ]]; then
            echo ""
            echo -e "${YELLOW}WARNING: This will overwrite current data!${NC}"
            read -p "Continue with restore? [y/N] " -n 1 -r
            echo
            [[ ! $REPLY =~ ^[Yy]$ ]] && exit 0
        fi

        RESTORE_DIR=$(mktemp -d)
        trap "rm -rf $RESTORE_DIR" EXIT INT TERM

        # Restore snapshot to temp directory
        echo -e "${YELLOW}Extracting snapshot...${NC}"
        if ! run_restic "$REPO" restore "$SNAPSHOT" --target "$RESTORE_DIR"; then
            echo -e "${RED}Failed to extract snapshot${NC}"
            exit 1
        fi

        # Check what was restored
        if [[ -f "$RESTORE_DIR/database.sql" ]]; then
            echo -e "${YELLOW}Restoring database...${NC}"

            # Restore database
            if ! $DC_CMD exec -T postgres bash -c 'PGPASSWORD=$POSTGRES_PASS psql -h localhost -U $POSTGRES_USER $POSTGRES_DBNAME' < "$RESTORE_DIR/database.sql"; then
                echo -e "${RED}Database restore failed${NC}"
                send_alert "Restore Failed" "Database restore failed at $(date)"
                exit 1
            fi
            echo -e "${GREEN}Database restored${NC}"
        fi

        # Check for uploads in the restored snapshot
        # With bind mounts, the snapshot preserves the original host path
        UPLOAD_HOST_DIR="$(realpath "${UPLOAD_HOST_DIR:-$SCRIPT_DIR/uploads}")"
        RESTORED_UPLOADS="$RESTORE_DIR$UPLOAD_HOST_DIR"

        if [[ -d "$RESTORED_UPLOADS" ]]; then
            echo -e "${YELLOW}Restoring uploads...${NC}"

            if [[ ! -d "$UPLOAD_HOST_DIR" ]]; then
                mkdir -p "$UPLOAD_HOST_DIR"
            fi

            rm -rf "${UPLOAD_HOST_DIR:?}"/*
            if ! cp -a "$RESTORED_UPLOADS"/. "$UPLOAD_HOST_DIR/"; then
                echo -e "${RED}Uploads restore failed${NC}"
                send_alert "Restore Failed" "Uploads restore failed at $(date)"
                exit 1
            fi
            echo -e "${GREEN}Uploads restored${NC}"
        fi

        echo -e "${GREEN}Restore complete!${NC}"
        ;;
        
    status)
        check_env
        load_env_vars DB_USER DB_NAME SCRAPER_RUNNER_URL
        echo -e "${YELLOW}Checking service status...${NC}"
        echo ""

        # Check PostgreSQL
        echo -n "PostgreSQL: "
        if $DC_CMD exec postgres pg_isready -U "${DB_USER:-timetiles_user}" -d "${DB_NAME:-timetiles}" > /dev/null 2>&1; then
            echo -e "${GREEN}✓ Healthy${NC}"
        else
            echo -e "${RED}✗ Unhealthy${NC}"
        fi

        # Check Web App
        echo -n "Web App: "
        if curl -f -s http://localhost/api/health > /dev/null 2>&1; then
            echo -e "${GREEN}✓ Healthy${NC}"
        else
            echo -e "${RED}✗ Unhealthy${NC}"
        fi

        # Check Nginx
        echo -n "Nginx: "
        NGINX_STATUS=$($DC_CMD ps --format '{{.Status}}' nginx 2>/dev/null | head -1)
        if [[ "$NGINX_STATUS" == *"healthy"* ]]; then
            echo -e "${GREEN}✓ Healthy${NC}"
        elif [[ "$NGINX_STATUS" == *"unhealthy"* ]]; then
            echo -e "${RED}✗ Unhealthy${NC}"
        elif [[ "$NGINX_STATUS" == *"Up"* ]]; then
            echo -e "${GREEN}✓ Running${NC}"
        else
            echo -e "${RED}✗ Not running${NC}"
        fi

        # Check Certbot
        echo -n "Certbot: "
        if $DC_CMD ps certbot 2>/dev/null | grep -q "Up"; then
            echo -e "${GREEN}✓ Running${NC}"
        else
            echo -e "${YELLOW}○ Not running (renewal only)${NC}"
        fi

        # Check Scraper Runner (if configured)
        if grep -q "^SCRAPER_RUNNER_URL=" "$ENV_FILE" 2>/dev/null; then
            echo -n "Scraper Runner: "
            if curl -f -s http://localhost:4000/health > /dev/null 2>&1; then
                echo -e "${GREEN}✓ Healthy${NC}"
            else
                echo -e "${RED}✗ Unhealthy${NC}"
            fi
        fi

        echo ""
        $DC_CMD ps
        ;;

    check)
        # Comprehensive deployment health check
        # Verifies all bootstrap steps are properly configured
        # Uses shared verification functions from bootstrap/lib/common.sh

        # Source shared verification functions
        BOOTSTRAP_LIB="$SCRIPT_DIR/bootstrap/lib/common.sh"
        if [[ -f "$BOOTSTRAP_LIB" ]]; then
            # Disable trap handler from common.sh (we handle our own exit)
            trap - EXIT INT TERM
            source "$BOOTSTRAP_LIB"
        fi

        ERRORS=0
        WARNINGS=0

        print_ok() { echo -e "${GREEN}✓${NC} $1"; }
        print_warn() { echo -e "${YELLOW}⚠${NC} $1"; WARNINGS=$((WARNINGS + 1)); }
        print_fail() { echo -e "${RED}✗${NC} $1"; ERRORS=$((ERRORS + 1)); }
        print_section() { echo -e "\n${YELLOW}=== $1 ===${NC}"; }

        # Run a verify function and print result
        # Usage: run_check verify_function_name
        run_check() {
            local func="$1"
            if type "$func" &>/dev/null; then
                "$func"
                local result=$?
                case $result in
                    0) print_ok "${CHECK_MSG:-}" ;;
                    1) print_warn "${CHECK_MSG:-}" ;;
                    *) print_fail "${CHECK_MSG:-}" ;;
                esac
            else
                print_warn "Check function not available: $func"
            fi
        }

        # Load only needed vars from env file (not secrets)
        if [[ -f "$ENV_FILE" ]]; then
            load_env_vars DOMAIN_NAME DB_USER DB_NAME SCRAPER_RUNNER_URL SCRAPER_API_KEY DEPLOY_USER
        fi

        print_section "System"
        run_check verify_ubuntu
        run_check verify_swap

        print_section "Security"
        run_check verify_ufw
        run_check verify_ssh_hardening
        run_check verify_fail2ban

        print_section "Docker"
        run_check verify_docker
        run_check verify_docker_compose
        run_check verify_docker_group

        print_section "Configuration"

        # Check env file (inline - specific to timetiles)
        if [[ -f "$ENV_FILE" ]]; then
            print_ok "Configuration file exists (.env.production)"

            # Check required vars
            MISSING_VARS=""
            for var in PAYLOAD_SECRET DB_PASSWORD DOMAIN_NAME; do
                val=$(grep "^$var=" "$ENV_FILE" 2>/dev/null | cut -d= -f2-)
                if [[ -z "$val" ]] || [[ "$val" == *"CHANGE_ME"* ]] || [[ "$val" == *"your-domain"* ]]; then
                    MISSING_VARS="${MISSING_VARS:+$MISSING_VARS, }$var"
                fi
            done
            if [[ -z "$MISSING_VARS" ]]; then
                print_ok "Required env vars configured"
            else
                print_fail "Missing/unconfigured vars: $MISSING_VARS"
            fi
        else
            print_fail "Configuration file missing (.env.production)"
        fi

        print_section "Application"

        # Check containers (inline - requires DC_CMD)
        if [[ -f "$ENV_FILE" ]]; then
            for container in postgres web nginx; do
                STATUS=$($DC_CMD ps --format '{{.Status}}' $container 2>/dev/null | head -1)
                if [[ "$STATUS" == *"Up"* ]]; then
                    if [[ "$STATUS" == *"healthy"* ]]; then
                        print_ok "$container container healthy"
                    elif [[ "$STATUS" == *"unhealthy"* ]]; then
                        print_fail "$container container unhealthy"
                    else
                        print_ok "$container container running"
                    fi
                else
                    print_fail "$container container not running"
                fi
            done

            # Check health endpoint
            if curl -f -s http://localhost/api/health > /dev/null 2>&1; then
                print_ok "Health endpoint responding"
            else
                print_fail "Health endpoint not responding"
            fi

            # Check database connection
            if $DC_CMD exec -T postgres pg_isready -U "${DB_USER:-timetiles_user}" -d "${DB_NAME:-timetiles}" > /dev/null 2>&1; then
                print_ok "Database connection working"
            else
                print_fail "Database connection failed"
            fi
        else
            print_warn "Skipping container checks (no config)"
        fi

        # Check scraper runner if configured
        if grep -q "^SCRAPER_RUNNER_URL=" "$ENV_FILE" 2>/dev/null; then
            print_section "Scraper Runner"

            # Check Podman installed
            if command -v podman &>/dev/null; then
                print_ok "Podman installed ($(podman --version | head -1))"
            else
                print_fail "Podman not installed"
            fi

            # Check base images (as deploy user)
            for img in timescrape-python timescrape-node; do
                if sudo -u "$DEPLOY_USER" podman images --format '{{.Repository}}' 2>/dev/null | grep -q "$img"; then
                    print_ok "Base image: $img"
                else
                    print_fail "Base image missing: $img"
                fi
            done

            # Check sandbox network
            if sudo -u "$DEPLOY_USER" podman network ls --format '{{.Name}}' 2>/dev/null | grep -q "^scraper-sandbox$"; then
                print_ok "Scraper sandbox network exists"
            else
                print_fail "Scraper sandbox network missing"
            fi

            # Check systemd service
            if systemctl is-active --quiet timescrape-runner.service 2>/dev/null; then
                print_ok "TimeScrape runner service running"
            else
                print_fail "TimeScrape runner service not running"
            fi

            # Check health endpoint
            if curl -f -s --max-time 5 http://localhost:4000/health > /dev/null 2>&1; then
                print_ok "Runner health endpoint responding"
            else
                print_fail "Runner health endpoint not responding"
            fi

            # Verify API key is configured (runner reads from same .env.production)
            SCRAPER_KEY=$(grep "^SCRAPER_API_KEY=" "$ENV_FILE" 2>/dev/null | cut -d= -f2-)
            if [[ -n "$SCRAPER_KEY" && ${#SCRAPER_KEY} -ge 16 ]]; then
                print_ok "SCRAPER_API_KEY configured (${#SCRAPER_KEY} chars)"
            elif [[ -n "$SCRAPER_KEY" ]]; then
                print_warn "SCRAPER_API_KEY too short (${#SCRAPER_KEY} chars, minimum 16)"
            else
                print_fail "SCRAPER_API_KEY not set in .env.production"
            fi
        fi

        print_section "SSL"

        # Check SSL certificate (inline - requires DC_CMD and DOMAIN_NAME)
        if [[ -n "$DOMAIN_NAME" ]]; then
            CERT_PATH="/etc/letsencrypt/live/$DOMAIN_NAME/fullchain.pem"
            # Check via docker if volume mounted
            CERT_INFO=$($DC_CMD exec -T nginx openssl x509 -in "$CERT_PATH" -noout -dates -subject 2>/dev/null)
            if [[ -n "$CERT_INFO" ]]; then
                EXPIRY=$(echo "$CERT_INFO" | grep "notAfter" | cut -d= -f2)
                EXPIRY_EPOCH=$(date -d "$EXPIRY" +%s 2>/dev/null || date -j -f "%b %d %T %Y %Z" "$EXPIRY" +%s 2>/dev/null)
                NOW_EPOCH=$(date +%s)
                DAYS_LEFT=$(( (EXPIRY_EPOCH - NOW_EPOCH) / 86400 ))

                if [[ "$DAYS_LEFT" -gt 30 ]]; then
                    print_ok "SSL certificate valid (expires in $DAYS_LEFT days)"
                elif [[ "$DAYS_LEFT" -gt 0 ]]; then
                    print_warn "SSL certificate expiring soon ($DAYS_LEFT days)"
                else
                    print_fail "SSL certificate expired"
                fi
            else
                # Check for self-signed fallback
                if [[ -f "$SCRIPT_DIR/ssl/live/$DOMAIN_NAME/fullchain.pem" ]]; then
                    print_warn "Using self-signed SSL certificate"
                else
                    print_fail "No SSL certificate found"
                fi
            fi
        else
            print_warn "DOMAIN_NAME not set, skipping SSL check"
        fi

        # Check certbot renewal
        if $DC_CMD ps certbot 2>/dev/null | grep -q "Up"; then
            print_ok "Certbot auto-renewal running"
        else
            print_warn "Certbot container not running"
        fi

        print_section "DNS"

        if [[ -n "$DOMAIN_NAME" ]]; then
            # Check IPv4 (A record)
            SERVER_V4=$(get_public_ip 2>/dev/null || echo "unknown")
            if [[ "$SERVER_V4" != "unknown" ]]; then
                DNS_V4=$(dig +short A "$DOMAIN_NAME" 2>/dev/null | grep -E '^[0-9]+\.' | head -1)
                if [[ -z "$DNS_V4" ]]; then
                    print_warn "No A record for $DOMAIN_NAME"
                elif [[ "$DNS_V4" == "$SERVER_V4" ]]; then
                    print_ok "A record: $DOMAIN_NAME → $SERVER_V4"
                else
                    print_fail "A record: $DOMAIN_NAME → $DNS_V4 (expected $SERVER_V4)"
                fi
            else
                print_warn "Could not determine server IPv4 address"
            fi

            # Check IPv6 (AAAA record)
            SERVER_V6=$(get_public_ipv6 2>/dev/null || echo "unknown")
            if [[ "$SERVER_V6" != "unknown" ]]; then
                DNS_V6=$(dig +short AAAA "$DOMAIN_NAME" 2>/dev/null | grep -E '^[0-9a-f:]+$' | head -1)
                if [[ -z "$DNS_V6" ]]; then
                    print_warn "No AAAA record for $DOMAIN_NAME (server has IPv6: $SERVER_V6)"
                elif [[ "$DNS_V6" == "$SERVER_V6" ]]; then
                    print_ok "AAAA record: $DOMAIN_NAME → $SERVER_V6"
                else
                    print_fail "AAAA record: $DOMAIN_NAME → $DNS_V6 (expected $SERVER_V6)"
                fi
            else
                print_ok "Server has no IPv6, AAAA check skipped"
            fi
        else
            print_warn "DOMAIN_NAME not set, skipping DNS check"
        fi

        print_section "Monitoring"
        run_check verify_backup_cron
        run_check verify_log_rotation
        run_check "verify_alerting $ALERT_SCRIPT"

        # Summary
        echo ""
        echo "======================================"
        if [[ $ERRORS -eq 0 ]] && [[ $WARNINGS -eq 0 ]]; then
            echo -e "${GREEN}ALL CHECKS PASSED${NC}"
            exit 0
        elif [[ $ERRORS -eq 0 ]]; then
            echo -e "${YELLOW}PASSED WITH $WARNINGS WARNING(S)${NC}"
            exit 0
        else
            echo -e "${RED}FAILED: $ERRORS ERROR(S), $WARNINGS WARNING(S)${NC}"
            exit 1
        fi
        ;;
        
    ssl)
        check_env
        init_ssl
        ;;
        
    update)
        check_env
        echo -e "${YELLOW}Updating TimeTiles...${NC}"
        # Pull latest deployment files if this is a git-based install
        if git rev-parse --git-dir &>/dev/null 2>&1; then
            git pull origin main
        fi
        if [ -f "$SCRIPT_DIR/docker-compose.override.yml" ]; then
            echo -e "${YELLOW}Rebuilding local images...${NC}"
            $DC_CMD build web
        else
            echo -e "${YELLOW}Pulling latest images from registry...${NC}"
            $DC_CMD pull
        fi
        # Recreate all services to pick up config/image changes
        $DC_CMD up -d
        echo -e "${GREEN}Services updated! Migrations will run automatically.${NC}"

        # Update scraper runner if configured
        if grep -q "^SCRAPER_RUNNER_URL=" "$ENV_FILE" 2>/dev/null; then
            load_env_vars TIMETILES_VERSION SCRAPER_IMAGE SCRAPER_PYTHON_IMAGE SCRAPER_NODE_IMAGE
            version="${TIMETILES_VERSION:-latest}"
            runner_dir="$SCRIPT_DIR/../scraper-runner"

            echo -e "${YELLOW}Updating scraper runner...${NC}"

            # Update runner: try GHCR image first, fall back to local build
            image="${SCRAPER_IMAGE:-ghcr.io/jfilter/timetiles-timescrape}:$version"
            rm -rf "${runner_dir:?}/dist" "${runner_dir:?}/node_modules" "${runner_dir:?}/package.json"

            # Helper: extract /app from image using tar (docker cp breaks pnpm symlinks)
            extract_runner() {
                local img="$1"
                docker rm -f tt-scraper-extract 2>/dev/null || true
                docker create --name tt-scraper-extract "$img"
                docker export tt-scraper-extract | tar -xf - -C "$runner_dir" --strip-components=1 app/dist app/node_modules app/package.json
                docker rm tt-scraper-extract
            }

            if docker pull "$image" 2>/dev/null; then
                extract_runner "$image"
            elif [[ -f "$SCRIPT_DIR/../apps/scraper/Dockerfile" ]]; then
                echo -e "${YELLOW}Registry pull failed, building runner locally...${NC}"
                docker build -t timescrape-runner-local -f "$SCRIPT_DIR/../apps/scraper/Dockerfile" "$SCRIPT_DIR/.."
                extract_runner timescrape-runner-local
            else
                echo -e "${RED}Cannot pull or build scraper runner${NC}"
            fi
            chown -R "$DEPLOY_USER:$DEPLOY_USER" "$runner_dir"

            # Update base images: try GHCR first, fall back to local build
            python_image="${SCRAPER_PYTHON_IMAGE:-ghcr.io/jfilter/timetiles-scraper-python:$version}"
            node_image="${SCRAPER_NODE_IMAGE:-ghcr.io/jfilter/timetiles-scraper-node:$version}"

            if sudo -u "$DEPLOY_USER" podman pull "$python_image" 2>/dev/null; then
                sudo -u "$DEPLOY_USER" podman tag "$python_image" timescrape-python
            elif [[ -f "$SCRIPT_DIR/../apps/scraper/images/python/Dockerfile" ]]; then
                sudo -u "$DEPLOY_USER" podman build -t timescrape-python "$SCRIPT_DIR/../apps/scraper/images/python/"
            fi

            if sudo -u "$DEPLOY_USER" podman pull "$node_image" 2>/dev/null; then
                sudo -u "$DEPLOY_USER" podman tag "$node_image" timescrape-node
            elif [[ -f "$SCRIPT_DIR/../apps/scraper/images/node/Dockerfile" ]]; then
                sudo -u "$DEPLOY_USER" podman build -t timescrape-node "$SCRIPT_DIR/../apps/scraper/images/node/"
            fi

            systemctl restart timescrape-runner
            echo -e "${GREEN}Scraper runner updated!${NC}"
        fi
        ;;

    version|--version|-v)
        # Try to get version from git tag or .version file
        if [[ -f "$SCRIPT_DIR/.version" ]]; then
            cat "$SCRIPT_DIR/.version"
        elif command -v git &>/dev/null && git -C "$SCRIPT_DIR" describe --tags 2>/dev/null; then
            : # git describe already printed
        else
            echo "unknown (no version info available)"
        fi
        ;;

    --help|-h|help)
        print_usage
        exit 0
        ;;

    *)
        print_usage
        exit 1
        ;;
esac
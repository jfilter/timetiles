# Docker Compose Override for Local Builds
#
# Copy to docker-compose.override.yml to build locally instead of pulling from registry.
# Useful for development or customization.
#
# Usage:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   ./timetiles build
#   ./timetiles up

services:
  web:
    build:
      context: ..
      dockerfile: deployment/Dockerfile.prod
      args:
        # DATABASE_URL and PAYLOAD_SECRET are NOT passed here because:
        # 1. Dockerfile.prod already uses dummy defaults for build-time compilation
        # 2. Passing real secrets as build args exposes them in image layer metadata
        # 3. Real values are injected at runtime via environment variables
        NEXT_PUBLIC_PAYLOAD_URL: ${NEXT_PUBLIC_PAYLOAD_URL:-http://localhost:3000}
    image: timetiles-web:local

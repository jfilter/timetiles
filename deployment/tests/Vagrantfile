# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"
  config.vm.hostname = "timetiles-test"
  config.vm.boot_timeout = 600
  config.ssh.keep_alive = true

  config.vm.provider "virtualbox" do |vb|
    vb.memory = "12288"
    vb.cpus = 4
    vb.name = "timetiles-test"
  end

  # Sync the deployment directory to /opt/timetiles (matches production layout after sparse checkout)
  config.vm.synced_folder "..", "/opt/timetiles", type: "rsync",
    rsync__exclude: [".git/", "node_modules/", ".next/", "dist/", ".turbo/", "coverage/", ".worktrees/",
                     ".env.production", ".env.local", "docker-compose.test.yml", "docker-compose.override.yml",
                     "credentials.txt", "ssl/", "nginx-test/", "uploads/", "backups/"]

  # Sync the full repo for local Docker builds (web app + scraper)
  # Dockerfile.prod needs the monorepo root as build context (COPY . . → turbo prune)
  # Use --links (not --copy-links) to avoid broken symlink errors from .gemini/.opencode
  config.vm.synced_folder "../..", "/opt/timetiles-src", type: "rsync",
    rsync__args: ["--verbose", "--archive", "--delete", "-z", "--links"],
    rsync__exclude: [".git/", "node_modules/", ".next/", "dist/", ".turbo/", "coverage/", ".worktrees/",
                     ".env.production", ".env.local",
                     "test-results/", "playwright-report/", ".test-results/",
                     "uploads/", "backups/", ".vagrant/",
                     ".claude/", ".agents/", ".gemini/", ".opencode/"]

  # Provision: set up build mode, install bats — bootstrap runs from run-vm.sh
  # (not as a provisioner, because Docker builds drop SSH connections)
  config.vm.provision "setup", type: "shell", inline: <<-SHELL
    LOCAL_BUILD="${LOCAL_BUILD:-true}"

    if [[ "$LOCAL_BUILD" == "true" ]]; then
      echo "==> Configuring local build mode (docker compose build)"

      cat > /opt/timetiles/docker-compose.override.yml << 'EOF'
services:
  web:
    build:
      context: /opt/timetiles-src
      dockerfile: deployment/Dockerfile.prod
      network: host
EOF

      ln -sfn /opt/timetiles-src/apps /opt/timetiles/apps
    else
      echo "==> Configuring GHCR pull mode (docker compose pull)"
      rm -f /opt/timetiles/docker-compose.override.yml
    fi

    # In GHCR mode, set edge version
    if [[ "$LOCAL_BUILD" != "true" ]]; then
      if [[ -f /opt/timetiles/.env.production ]]; then
        sed -i 's/^TIMETILES_VERSION=.*/TIMETILES_VERSION=edge/' /opt/timetiles/.env.production
      fi
    fi

    # Fix permissions
    chmod -R a+rX /opt/timetiles
    chmod -R a+rX /opt/timetiles-src 2>/dev/null || true

    # Install bats
    apt-get install -y -qq bats
  SHELL
end

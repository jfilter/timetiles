{
  "name": "timetiles",
  "version": "0.0.1",
  "private": true,
  "description": "A data explorer for spatio-temporal data with custom metadata.",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:devops": "actionlint -shellcheck= && find . -name 'Dockerfile*' -type f | grep -v node_modules | grep -v .worktrees | grep -v .claude | xargs hadolint && find . \\( -name 'Makefile' -o -name '*.mk' \\) -type f | grep -v node_modules | grep -v .worktrees | grep -v .claude | xargs checkmake --config=.checkmake && find . -name '*.sh' -type f | grep -v node_modules | grep -v .worktrees | grep -v .claude | xargs shellcheck --exclude=SC1091,SC2016",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:merge": "tsx scripts/merge-coverage.ts",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "check": "turbo run lint typecheck",
    "setup:git": "./scripts/setup-git.sh",
    "sonarcloud:fetch": "tsx scripts/fetch-sonarcloud-issues.ts",
    "sonarcloud:review": "tsx scripts/review-sonarcloud-hotspots.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@timetiles/eslint-config": "workspace:*",
    "@timetiles/typescript-config": "workspace:*",
    "@typescript/native-preview": "beta",
    "chalk": "^5.6.2",
    "eslint-plugin-oxlint": "^1.69.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "nyc": "^18.0.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsx": "catalog:",
    "turbo": "^2.9.18",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.12.4",
  "pnpm": {
    "overrides": {
      "pino": "^10.3.1",
      "@headlessui/react": "^2.2.6",
      "@theguild/remark-mermaid": "^0.0.7",
      "next-mdx-remote": "^5.0.0",
      "form-data": "^4.0.4",
      "cross-spawn": "^7.0.6",
      "dompurify": "^3.4.7",
      "esbuild": "^0.25.0",
      "undici@7": "^7.24.0",
      "immutable": "^4.3.8",
      "ws": "^8.20.1",
      "fast-uri": "^3.1.2",
      "postcss": "^8.5.10",
      "protocol-buffers-schema": "^3.6.1",
      "icu-minify": "^4.9.2",
      "@xmldom/xmldom": "^0.9.10",
      "picomatch@2": "^2.3.2",
      "brace-expansion@2": "^2.0.3",
      "brace-expansion@5": "^5.0.6",
      "ajv@8": "^8.20.0",
      "uuid@11": "^11.1.1",
      "uuid@13": "^13.0.1",
      "yaml@2": "^2.8.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [
        "monaco-editor",
        "yjs",
        "puppeteer"
      ],
      "allowedVersions": {
        "@theguild/remark-mermaid>react": "^19",
        "@typescript-eslint/utils>eslint": "^9"
      }
    }
  }
}

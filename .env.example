# Database Configuration
# PG_MODE: "docker" (default, port 5432) or "local" (Homebrew PostgreSQL, port 5433)
PG_MODE=docker
DATABASE_URL=postgresql://timetiles_user:timetiles_password@localhost:5432/timetiles

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000


# Payload CMS Configuration
PAYLOAD_SECRET=your-payload-secret-key-here
PAYLOAD_CONFIG_PATH=payload.config.ts

# TimeScrape Runner Configuration
# SCRAPER_API_KEY=your-scraper-api-key-here
# SCRAPER_PORT=4000
# SCRAPER_RUNNER_URL=http://localhost:4000
# SCRAPER_MAX_CONCURRENT=3
# SCRAPER_DEFAULT_TIMEOUT=300
# SCRAPER_DEFAULT_MEMORY=512

# Optional: For production
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=timetiles
# POSTGRES_USER=timetiles_user
# POSTGRES_PASSWORD=timetiles_password

{
  "name": "@timetiles/eslint-config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./base": "./base.js",
    "./next-js": "./next.js",
    "./react-internal": "./react-internal.js",
    "./mdx": "./mdx.js",
    "./vitest": "./vitest.js"
  },
  "scripts": {
    "lint": "mkdir -p .lint-results && eslint . --ext .ts,.tsx --cache --format json --output-file .lint-results/latest.json; eslint . --ext .ts,.tsx --cache",
    "format": "oxlint --config ../../.oxlintrc.json --fix . && oxfmt --write ."
  },
  "dependencies": {
    "@eslint/js": "^9.39.2"
  },
  "devDependencies": {
    "eslint": "catalog:",
    "eslint-plugin-jsdoc": "^62.4.1",
    "eslint-plugin-mdx": "^3.6.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.2.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.54.0"
  }
}

{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "PAYLOAD_SECRET",
    "NEXT_PUBLIC_PAYLOAD_URL",
    "CI",
    "GITHUB_ACTIONS",
    "VITEST",
    "VITEST_WORKER_ID",
    "LOG_LEVEL",
    "LOG_FILE",
    "UPLOAD_DIR",
    "UPLOAD_TEMP_DIR",
    "TEST_ALL_BROWSERS",
    "E2E_DEBUG",
    "E2E_MODE",
    "PGPASSWORD",
    "SKIP_EXTERNAL",
    "URL_FETCH_TEST_TIMEOUT_MS",
    "EMAIL_FROM_ADDRESS",
    "EMAIL_FROM_NAME",
    "EMAIL_SMTP_HOST",
    "EMAIL_SMTP_PORT",
    "EMAIL_SMTP_USER",
    "EMAIL_SMTP_PASS",
    "DATA_EXPORT_DIR",
    "ALLOW_PRIVATE_URLS",
    "SCRAPER_API_KEY",
    "SCRAPER_PORT",
    "SCRAPER_RUNNER_URL",
    "SCRAPER_MAX_CONCURRENT",
    "SCRAPER_DEFAULT_TIMEOUT",
    "SCRAPER_DEFAULT_MEMORY",
    "SCRAPER_MAX_REPO_SIZE_MB",
    "SCRAPER_MAX_OUTPUT_SIZE_MB",
    "SCRAPER_DATA_DIR",
    "NEXT_PHASE",
    "SKIP_DB_CHECK",
    "NEXT_PUBLIC_SITE_URL",
    "DEFAULT_LOCALE",
    "SSRF_DNS_CHECK",
    "URL_FETCH_CACHE_DIR",
    "URL_FETCH_CACHE_TTL"
  ],
  "tasks": {
    "transit": { "dependsOn": ["^transit"] },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["transit"],
      "inputs": [
        "**/*.{ts,tsx,js,jsx}",
        "content/**/*.{md,mdx}",
        "scripts/**/*.ts",
        "eslint.config.js",
        ".eslintrc*",
        ".eslintignore",
        "../../.oxlintrc.json"
      ],
      "outputs": [".lint-results/**"]
    },
    "format": { "inputs": ["**/*.{ts,tsx,js,jsx,md,json,yml,yaml}"] },
    "typecheck": {
      "dependsOn": ["transit"],
      "inputs": ["**/*.{ts,tsx}", "tsconfig.json", "tsconfig.*.json"],
      "outputs": [".typecheck-results/**"]
    },
    "typecheck:fast": {
      "dependsOn": ["transit"],
      "inputs": ["**/*.{ts,tsx}", "tsconfig.json", "tsconfig.*.json"],
      "outputs": [".typecheck-results/**"]
    },
    "dev": { "cache": false, "persistent": true },
    "storybook": { "cache": false, "persistent": true },
    "storybook:build": { "dependsOn": ["^build"], "outputs": ["storybook-static/**"] },
    "test": {
      "dependsOn": ["transit"],
      "inputs": [
        "lib/**/*.ts",
        "lib/**/*.tsx",
        "app/**/*.ts",
        "app/**/*.tsx",
        "components/**/*.ts",
        "components/**/*.tsx",
        "src/**/*.ts",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "migrations/**/*",
        "vitest.config.ts",
        "vitest.config.base.ts",
        "vitest.workspace.ts",
        "payload.config.ts"
      ],
      "outputs": [".test-results/**", "coverage/**"]
    },
    "test:ai": {
      "dependsOn": ["transit"],
      "inputs": [
        "lib/**/*.ts",
        "lib/**/*.tsx",
        "app/**/*.ts",
        "app/**/*.tsx",
        "components/**/*.ts",
        "components/**/*.tsx",
        "src/**/*.ts",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "migrations/**/*",
        "vitest.config.ts",
        "vitest.config.base.ts",
        "vitest.workspace.ts",
        "payload.config.ts"
      ],
      "outputs": [".test-results/**"]
    },
    "test:coverage": {
      "dependsOn": ["transit"],
      "outputs": ["coverage/**", ".nyc_output/**", "coverage.json"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    }
  }
}

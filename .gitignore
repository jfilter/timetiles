# Generated API Documentation
# These files are auto-generated from JSDoc comments via TypeDoc
# Run TypeDoc from apps/web, then run conversion scripts in apps/docs/scripts/
apps/docs/content/reference/api/**/*.md
apps/docs/content/reference/api/**/*.mdx
apps/docs/content/reference/api/**/_meta.json
apps/docs/content/reference/api/**/_meta.js
# Keep only the manual index file
!apps/docs/content/reference/api/index.mdx
.playwright-mcp
.agents
.worktrees/
.vagrant/

